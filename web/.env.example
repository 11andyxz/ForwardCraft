# ForwardCraft — environment variables for the Careers application flow.
# Copy this file to `.env.local` and fill in real values. NEVER commit .env.local.
# In production, set these in the Vercel project's Environment Variables.

# --- Database (Aiven MySQL) ---
# The full Service URI from the Aiven console, e.g.:
#   mysql://USER:PASSWORD@HOST:PORT/defaultdb?ssl-mode=REQUIRED
DATABASE_URL=

# Optional but recommended: the Aiven CA certificate (PEM) for strict TLS
# verification. Paste the full certificate. Without it, TLS is still used but
# the chain is not verified. In Vercel, paste the multi-line PEM directly.
MYSQL_CA_CERT=

# --- File storage (Vercel Blob) ---
# Created automatically when you add a Blob store to the Vercel project.
# For local development, copy the token from the Vercel dashboard.
BLOB_READ_WRITE_TOKEN=

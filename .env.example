# ForwardCraft 环境变量示例
# 复制为 .env 后按需修改(.env 已被 .gitignore 忽略,不会提交)

# 日志级别:DEBUG / INFO / WARNING / ERROR
FORWARDCRAFT_LOG_LEVEL=INFO

# 本地数据目录
FORWARDCRAFT_DATA_DIR=data

